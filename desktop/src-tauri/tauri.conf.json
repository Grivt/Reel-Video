{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pixelle Video",
  "version": "0.1.0",
  "identifier": "com.pixelle.video",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pixelle Video",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/pixelle-api": "binaries/pixelle-api",
      "binaries/ffprobe*": "binaries",
      "../../templates": "templates",
      "../../workflows": "workflows",
      "../../bgm": "bgm",
      "../../resources": "resources",
      "../../web/i18n/locales": "web/i18n/locales"
    },
    "category": "Productivity",
    "shortDescription": "AI 全自动短视频生成桌面端",
    "longDescription": "Pixelle Video 桌面端：输入主题即可自动生成视频文案、AI 配图、TTS 语音并合成视频。基于 Tauri 2.0 跨平台。"
  }
}
